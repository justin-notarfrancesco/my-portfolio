---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Work' },
  { href: '/contact', label: 'Contact' },
];

// Normalize the current path to detect the active link (handles trailing slash + nested routes).
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path === href || path.startsWith(href + '/'));
---

<header class="nav">
  <a href="#main" class="skip-link">Skip to content</a>
  <div class="nav__inner container">
    <a class="brand" href="/" aria-label="Justin Notarfrancesco — home" data-umami-event="nav-click" data-umami-event-destination="/">
      <img class="brand__bullet" src="/subway/J.svg" alt="" width="48" height="48" />
      <span class="brand__divider" aria-hidden="true"></span>
      <span class="brand__text">
        <span class="brand__name">Justin Notarfrancesco</span>
        <span class="brand__sub label">
          <span class="brand__status" aria-hidden="true"></span>
          New York City
        </span>
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav__checkbox sr-only" aria-hidden="true" />
    <label for="nav-toggle" class="nav__burger" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav__menu" aria-label="Primary">
      <ul>
        {
          links.map((l) => (
            <li>
              {isActive(l.href) ? (
                <span class="nav__link is-active" aria-current="page">
                  {l.label}
                </span>
              ) : (
                <a href={l.href} class="nav__link" data-umami-event="nav-click" data-umami-event-destination={l.href}>
                  {l.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-block-size: var(--nav-h);
  }

  .skip-link {
    position: absolute;
    left: 0.5rem;
    top: 0.5rem;
    transform: translateY(-150%);
    background: var(--color-link);
    color: #000;
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius);
    font-weight: 700;
    transition: transform 0.15s ease;
    z-index: 60;
  }
  .skip-link:focus {
    transform: translateY(0);
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius);
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__bullet {
    display: block;
    inline-size: 40px;
    block-size: 40px;
    flex: none;
    transition:
      transform 0.15s ease,
  }
  .brand:hover .brand__bullet {
    transform: scale(1.06);
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--mta-brown) 70%, transparent));
  }
  .brand:active .brand__bullet {
    transform: scale(0.98);
  }

  /* Station-signage divider between the route bullet and the name */
  .brand__divider {
    inline-size: 1px;
    block-size: 28px;
    background: var(--color-rule);
    flex: none;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1;
  }
  .brand__name {
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: 0;
    white-space: nowrap;
  }
  .brand__sub {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-dim);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    transition: color 0.15s ease;
  }
  .brand:hover .brand__sub {
    color: var(--color-text);
  }

  /* "In service" indicator — a live arrival-board pulse */
  .brand__status {
    inline-size: 6px;
    block-size: 6px;
    border-radius: 50%;
    background: var(--mta-green);
    flex: none;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--mta-green) 60%, transparent);
    animation: brand-pulse 2.4s ease-out infinite;
  }
  @keyframes brand-pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--mta-green) 55%, transparent);
    }
    70%,
    100% {
      box-shadow: 0 0 0 5px transparent;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand__status {
      animation: none;
    }
  }

  .nav__menu ul {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    color: var(--color-text);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    border-radius: var(--radius);
    border-bottom: 3px solid transparent;
    text-decoration: none;
  }
  .nav__link:hover {
    color: var(--color-link);
    text-decoration: none;
  }
  .nav__link.is-active {
    border-bottom-color: var(--color-primary);
    color: #fff;
  }

  /* --- Mobile menu (CSS-only, no JS) --- */
  .nav__checkbox {
    position: absolute;
  }
  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    cursor: pointer;
    border-radius: var(--radius);
  }
  .nav__burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-text);
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .nav__checkbox:focus-visible + .nav__burger {
    outline: 3px solid var(--focus);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .nav__burger {
      display: flex;
    }
    .nav__menu {
      position: absolute;
      inset: var(--nav-h) 0 auto 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-rule);
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.25s ease;
    }
    .nav__menu ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      overflow: hidden;
      padding-inline: var(--gutter);
    }
    .nav__menu li {
      border-bottom: 1px solid var(--color-rule);
    }
    .nav__link {
      display: block;
      padding: 1rem 0.25rem;
      border-bottom: 3px solid transparent;
    }
    .nav__checkbox:checked ~ .nav__menu {
      grid-template-rows: 1fr;
    }
    .nav__checkbox:checked + .nav__burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav__checkbox:checked + .nav__burger span:nth-child(2) {
      opacity: 0;
    }
    .nav__checkbox:checked + .nav__burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
