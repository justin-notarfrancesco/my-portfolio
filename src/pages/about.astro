---
import Layout from '../layouts/Layout.astro';
import LineBadge from '../components/LineBadge.astro';
import { PERSON, SITE_URL } from '../lib/schema';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${SITE_URL}/about#page`,
  url: `${SITE_URL}/about`,
  name: 'About Justin Notarfrancesco',
  mainEntity: PERSON,
};

// Skills grouped like a service guide, each mapped to a line color.
const skillGroups = [
  {
    line: 'A',
    title: 'Core',
    skills: ['TypeScript', 'JavaScript (ESNext)', 'HTML5', 'Semantic CSS'],
  },
  {
    line: 'F',
    title: 'Frameworks',
    skills: ['Astro', 'React', 'Svelte', 'Next.js'],
  },
  {
    line: 'N',
    title: 'Design & UI',
    skills: ['Design Systems', 'Figma', 'Motion', 'Data Visualization'],
  },
  {
    line: '6',
    title: 'Quality',
    skills: ['Accessibility (WCAG)', 'Performance', 'Testing', 'CI/CD'],
  },
  {
    line: 'L',
    title: 'Platform',
    skills: ['Node.js', 'Vite', 'Edge Functions', 'Web Components'],
  },
];

const stats = [
  { value: '5+', label: 'Years Experience', line: '3' },
  { value: '4+', label: 'Projects Shipped', line: 'F' },
  { value: 'NYC', label: 'Home Base', line: '7', express: true },
];
---

<Layout
  title="About"
  description="About Justin Notarfrancesco — a senior frontend engineer in New York City with five years building financial interfaces at JPMorgan Chase."
  type="profile"
>
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(schema)} />
  <section class="section">
    <div class="container">
      <header class="page-head">
        <p class="eyebrow"><LineBadge label="E" size={32} eager /> <span class="eyebrow__eta mono">Station Guide</span></p>
        <h1>About</h1>
      </header>

      <div class="about">
        <div class="about__bio stack">
          <p class="lede">
            I&rsquo;m Justin — a senior frontend engineer based in <a href="https://en.wikipedia.org/wiki/Manhattan" target="_blank" rel="noopener noreferrer"><i>Manhattan</i></a>. I&rsquo;ve spent the last
            five years building financial interfaces at JPMorgan Chase — web products where speed, accessibility, and to-the-cent
            correctness are non-negotiable. <b>I build digital products that people love to use.</b>
          </p>
          <p class="text-dim">
            My approach borrows from the city I live in: the best systems, like the subway, disappear into
            usefulness. Good wayfinding, honest typography, a strict grid, and color that means something.
            I care about the details a user never consciously notices — the ones that make an interface feel
            effortless.
          </p>
          <p class="text-dim">
            I&rsquo;ve led design-system work, shipped headless commerce, and built the kind of financial
            UI where a ledger has to reconcile to the cent and a transfer needs two sets of eyes.
            I&rsquo;m happiest at the intersection of engineering rigor and design craft, translating between
            the two so a team can move fast without breaking the experience.
          </p>

          <ul class="stats" aria-label="At a glance">
            {
              stats.map((s) => (
                <li class="stat">
                  <LineBadge label={s.line} size={32} title={s.label} express={s.express} />
                  <span class="stat__value">{s.value}</span>
                  <span class="stat__label label text-dim">{s.label}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <hr class="about__divider" />

      <section class="skills" aria-labelledby="skills-title">
        <div class="section-head">
          <p class="eyebrow"><LineBadge label="N" size={32} /> <span class="eyebrow__eta mono">Service Guide</span></p>
          <h2 id="skills-title">Skills &amp; Tech Stack</h2>
        </div>

        <div class="grid skills__grid">
          {
            skillGroups.map((g) => (
              <div class="skill-group">
                <div class="skill-group__head">
                  <LineBadge label={g.line} size={32} title={g.title} />
                  <h3>{g.title}</h3>
                </div>
                <ul>
                  {g.skills.map((s) => <li>{s}</li>)}
                </ul>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</Layout>

<style>
  .about {
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .lede {
    font-size: 1.3rem;
    line-height: 1.5;
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    list-style: none;
    margin: 2rem 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--color-rule);
  }
  .stat {
    display: grid;
    grid-template-columns: auto auto;
    grid-template-rows: auto auto;
    column-gap: 0.6rem;
    align-items: center;
  }
  .stat :global(.line-badge) {
    grid-row: span 2;
  }
  .stat__value {
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
  }
  .stat__label {
    grid-column: 2;
  }

  .about__media {
    position: relative;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
    position: sticky;
    top: calc(var(--nav-h) + 1.5rem);
  }
  .about__media img {
    width: 100%;
    height: auto;
  }
  .about__plate {
    position: absolute;
    inset: auto 0 0 0;
    padding: 0.6rem 0.9rem;
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    color: var(--mta-yellow);
    letter-spacing: 0.12em;
    border-top: 2px solid var(--mta-yellow);
  }

  .about__divider {
    border: 0;
    margin-block: clamp(2.5rem, 6vw, 4rem);
  }

  .section-head {
    margin-bottom: 2rem;
  }
  .skills__grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .skill-group {
    padding: 1.25rem;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .skill-group__head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.9rem;
  }
  .skill-group__head h3 {
    margin: 0;
    font-size: 1.05rem;
  }
  .skill-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .skill-group li {
    font-size: 0.9rem;
    color: var(--color-text-dim);
    padding-left: 0.9rem;
    position: relative;
  }
  .skill-group li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-text-dim);
  }

  @media (max-width: 900px) {
    .skills__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 780px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__media {
      order: -1;
      max-width: 320px;
      position: static;
    }
  }
  @media (max-width: 520px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
