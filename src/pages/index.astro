---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import LineBadge from '../components/LineBadge.astro';
import NowArriving from '../components/NowArriving.astro';
import ProjectCard from '../components/ProjectCard.astro';
import profile from '../assets/profile.svg';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((p) => p.data.featured).slice(0, 3);
const featuredList = featured.length ? featured : projects.slice(0, 3);
---

<Layout>
  <!-- NOW ARRIVING -->
  <div class="container hero__arriving">
    <NowArriving />
  </div>

  <!-- HERO -->
  <section class="hero section">
    <div class="container hero__grid">
      <div class="hero__intro">
        <h1 class="hero__name">Justin<br />Notarfrancesco</h1>
        <p class="hero__title label">Senior Frontend Engineer</p>
        <p class="hero__tagline text-dim">
          Your favorite engineer's favorite engineer.
        </p>

        <div class="hero__actions">
          <ul class="hero__lines" aria-label="Selected technologies">
            <li><LineBadge label="N" size={32} title="React" eager /> React</li>
            <li><LineBadge label="A" size={32} title="TypeScript" eager /> TypeScript</li>
            <li><LineBadge label="B" size={32} title="HTML & CSS" eager /> HTML/CSS</li>
            <li><LineBadge label="6" size={32} title="Accessibility" eager /> Accessibility</li>
          </ul>

          <div class="hero__cta">
            <a class="btn btn--primary" href="/projects">View Work &rarr;</a>
          </div>
        </div>
      </div>

      <div class="hero__media">
        <Image src={profile} alt="Portrait of Justin Notarfrancesco" width={480} height={560} loading="eager" />
      </div>
    </div>
  </section>

  <!-- FEATURED WORK -->
  <section class="section featured">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow"><LineBadge label="7" size={32} title="7 express" express /> <span class="eyebrow__eta mono">EXPRESS SERVICE</span></p>
        <div class="section-head__row">
          <h2>Featured Work</h2>
          <a class="section-head__all" href="/projects">All stops &rarr;</a>
        </div>
      </div>

      <div class="grid cards">
        {
          featuredList.map((p) => (
            <ProjectCard
              slug={p.id}
              title={p.data.title}
              description={p.data.description}
              techStack={p.data.techStack}
              image={p.data.image}
              line={p.data.line}
              lineColor={p.data.lineColor}
              year={p.data.year}
            />
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero__arriving {
    /* Carry the hero's top spacing so the eyebrow sits right above the hero
       content instead of the section padding pushing it far away. */
    padding-top: clamp(3.5rem, 8vw, 6.5rem);
    /* Explicit gap (not the eyebrow's collapsing margin) so the space below
       the eyebrow exactly matches the Express Service -> Featured Work gap. */
    padding-bottom: 1.5rem;
  }
  .hero__arriving .eyebrow {
    margin-bottom: 0;
  }
  .hero.section {
    padding-block: 0;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: start;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .hero__name {
    /* MTA station-name signage (Helvetica) uses neutral-to-open tracking,
       not the tight negative default — keeps "rf" and other pairs from touching. */
    letter-spacing: 0.01em;
    margin-block: 0.25rem 0.75rem;
  }
  .hero__title {
    color: var(--color-accent);
    font-size: 0.95rem;
    letter-spacing: 0.2em;
    margin-bottom: 1.25rem;
  }
  .hero__tagline {
    font-size: 1.15rem;
    max-width: 46ch;
    margin-bottom: 1.75rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__lines {
    display: grid;
    grid-template-columns: repeat(2, auto);
    gap: 0.75rem 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .hero__lines li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .hero__media {
    position: relative;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
  }
  .hero__media img {
    width: 100%;
    height: auto;
    display: block;
  }
  .hero__plate {
    position: absolute;
    left: 0;
    bottom: 0;
    right: 0;
    padding: 0.6rem 0.9rem;
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(6px);
    color: var(--mta-yellow);
    letter-spacing: 0.12em;
    border-top: 2px solid var(--mta-yellow);
  }

  .section-head {
    margin-bottom: 2rem;
  }
  .section-head__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .section-head__all {
    font-weight: 700;
    white-space: nowrap;
  }

  .cards {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 900px) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 820px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__media {
      order: -1;
      max-width: 340px;
    }
  }
  @media (max-width: 560px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
